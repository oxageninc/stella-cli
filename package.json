{
  "name": "stella-monorepo",
  "private": true,
  "description": "The stella monorepo \u2014 the Rust workspace for the stella CLI plus the docs site (stella-docs/). Rust builds stay pure cargo; pnpm orchestrates the web packages and bridges common tasks.",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter stella-cli-docs dev",
    "build": "pnpm --filter stella-cli-docs build",
    "start": "pnpm --filter stella-cli-docs start",
    "typecheck": "pnpm --filter stella-cli-docs typecheck",
    "docs:dev": "pnpm --filter stella-cli-docs dev",
    "docs:build": "pnpm --filter stella-cli-docs build",
    "rust:build": "cargo build --workspace",
    "rust:test": "cargo test --workspace",
    "rust:lint": "cargo clippy --workspace --all-targets -- -D warnings",
    "rust:fmt": "cargo fmt --all",
    "gate": "make gate"
  }
}
